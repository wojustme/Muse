HOST=127.0.0.1
PORT=8787

# 模型 provider
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# GLM_API_KEY=

# MariaDB 连接串
DATABASE_URL=mysql://muse:muse@127.0.0.1:3306/muse_db

# 服务端对外可访问的 base URL，用于拼接 OAuth redirect_uri
# 飞书控制台【安全设置 → 重定向 URL】需填 {PUBLIC_BASE_URL}/api/auth/feishu/callback
PUBLIC_BASE_URL=http://127.0.0.1:8787
FRONTEND_BASE_URL=http://127.0.0.1:1420

# 登录态
SESSION_TOKEN_TTL_HOURS=720
LOGIN_CHALLENGE_TTL_SECONDS=300

# 本地前端联调用：启用后 /api/auth/dev 会签发真实 session。
AUTH_DEV_MOCK=false
AUTH_DEV_MOCK_NAME=Muse Dev User
