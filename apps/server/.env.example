HOST=127.0.0.1
PORT=8787

# 模型 provider
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# GLM_API_KEY=

# 本地 SQLite 路径
DATABASE_PATH=./muse.db

# 服务端对外可访问的 base URL，用于拼接 OAuth redirect_uri
# 飞书控制台【安全设置 → 重定向 URL】需填 {PUBLIC_BASE_URL}/api/auth/feishu/callback
PUBLIC_BASE_URL=http://127.0.0.1:8787

# 登录态
SESSION_TOKEN_TTL_HOURS=720
LOGIN_CHALLENGE_TTL_SECONDS=300

# 飞书自建应用（凭证与基础信息页获取）。未配置则飞书 provider 不注册。
FEISHU_APP_ID=
FEISHU_APP_SECRET=
