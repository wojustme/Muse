{
  "name": "muse",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel dev:server dev:desktop",
    "dev:desktop": "node scripts/muse-dev-desktop.mjs",
    "dev:desktop:web": "pnpm --filter @muse/desktop run dev:web",
    "dev:desktop:tauri": "pnpm --filter @muse/desktop run dev:tauri",
    "dev:mobile:web": "pnpm --filter @muse/mobile run dev:web",
    "dev:mobile:ios": "pnpm --filter @muse/mobile run dev:ios",
    "dev:mobile:android": "pnpm --filter @muse/mobile run dev:android",
    "ios:init": "pnpm --filter @muse/mobile run ios:init",
    "ios:build": "pnpm --filter @muse/mobile run ios:build",
    "android:init": "pnpm --filter @muse/mobile run android:init",
    "android:build": "pnpm --filter @muse/mobile run android:build",
    "dev:server": "pnpm --filter @muse/server run dev",
    "build": "pnpm -r --sort run build",
    "typecheck": "pnpm -r --sort run typecheck",
    "lint": "pnpm -r --sort run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  }
}
